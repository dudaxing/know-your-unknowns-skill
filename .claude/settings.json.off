{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "D:/ProgramData/Anaconda3/python.exe .cursor/hooks/run_claude_plan_gate.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "D:/ProgramData/Anaconda3/python.exe .cursor/hooks/run_claude_bash_gate.py"
          }
        ]
      }
    ]
  }
}
