{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "D:/ProgramData/Anaconda3/python.exe .cursor/hooks/plan_gate_cursor.py",
        "matcher": "Write|StrReplace|Delete|EditNotebook",
        "failClosed": true,
        "timeout": 30
      }
    ],
    "beforeShellExecution": [
      {
        "command": "D:/ProgramData/Anaconda3/python.exe .cursor/hooks/bash_gate_cursor.py",
        "failClosed": true,
        "timeout": 30
      }
    ]
  }
}
